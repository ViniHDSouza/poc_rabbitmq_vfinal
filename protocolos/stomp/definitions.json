{
  "vhosts": [
    { "name": "/" }
  ],
  "users": [
    {
      "name": "rabbitmq",
      "password": "rabbitmq",
      "tags": ["administrator"]
    }
  ],
  "permissions": [
    {
      "user": "rabbitmq",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "pessoa.exchange",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "pessoa.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "pessoa.exchange",
      "vhost": "/",
      "destination": "pessoa.queue",
      "destination_type": "queue",
      "routing_key": "pessoa.routing-key",
      "arguments": {}
    }
  ]
}
